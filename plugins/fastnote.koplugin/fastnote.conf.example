-- fastnote.koplugin — user configuration
--
-- HOW TO ACTIVATE
-- ---------------
-- Copy (or rename) this file to:
--
--   koreader/settings/fastnote.conf
--
-- On a Kobo device that is usually:
--   /mnt/onboard/.adds/koreader/settings/fastnote.conf
--
-- Edit the values below, then restart KOReader.
-- Missing keys fall back to the built-in defaults shown here.

return {

    -- finger_draw
    -- -----------
    -- Allow drawing with finger (capacitive touch) in addition to the pen.
    --
    --   false  (default) — pen-only mode.
    --              Capacitive touch events are ignored while the raw pen
    --              driver is active, so accidental palm / finger marks
    --              cannot appear.  Recommended for normal use.
    --
    --   true   — pen + finger both draw.
    --              Useful for testing in the SDL emulator (which has no
    --              Wacom digitizer and falls back to the gesture path), or
    --              if you prefer sketching with your finger.
    --
    finger_draw = false,

    -- rotation_mode
    -- -------------
    -- Screen orientation when the canvas opens.  The canvas locks to this
    -- orientation and ignores accelerometer-based auto-rotation while it is
    -- open; you can still change orientation from the in-canvas menu.
    --
    --   "auto"  (default) — inherit whatever orientation is currently active
    --              when the canvas opens.  This is the recommended default.
    --
    --   0       — always open in portrait (upright).
    --   3       — always open in landscape with buttons at the bottom
    --              (counter-clockwise rotation — recommended for Kobo Libra).
    --   1       — landscape with buttons at the top (clockwise rotation).
    --   2       — portrait upside-down.
    --
    rotation_mode = "auto",

    -- debug_input_log
    -- ---------------
    -- Write a timestamped raw + decoded event log to fastnote/input.log.
    -- Useful for diagnosing eraser detection, hover glitches, and other
    -- hardware input issues.  Tail the log over SSH:
    --
    --   tail -F /mnt/onboard/.adds/koreader/fastnote/input.log
    --
    -- Also togglable live from the hamburger menu ("Debug log: off/on")
    -- without restarting KOReader.
    --
    --   false  (default) — logging off.  No overhead at runtime.
    --   true   — log enabled on canvas open.
    --
    debug_input_log = false,

    -- develop_delay
    -- -------------
    -- Seconds of pen inactivity after which a deferred colour develop
    -- refresh fires.  The develop refresh renders strokes in their chosen
    -- ink colour via a full colour-capable partial refresh (Kaleido 3).
    -- Only active on colour hardware; ignored on monochrome / emulator.
    --
    --   5  (default) — fire 5 seconds after the last pen-up.
    --
    develop_delay = 5,

    -- develop_enabled
    -- ---------------
    -- Whether to perform the deferred colour develop refresh.
    --
    --   true   (default) — A2 strokes "bloom" into colour ~develop_delay
    --              seconds after the pen lifts.
    --   false  — draw-time A2 only; no deferred colour refresh.
    --              Use if you find the periodic refresh distracting.
    --
    develop_enabled = true,

}
