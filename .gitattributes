# Declare files that will always have LF line endings on checkout.
# This is the default for most text files, but explicitly setting it ensures consistency.
* text=auto eol=lf

# Explicitly declare binary files to prevent Git from trying to auto-convert them.
# Add common binary file extensions here.
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.bmp binary
*.tiff binary
*.tif binary
*.webp binary
*.pdf binary
*.zip binary
